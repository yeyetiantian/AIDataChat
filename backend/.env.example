# ============================================================
# LLM 提供商选择
# ============================================================
# openai: 使用 OpenAI 兼容接口（默认，支持 gpt-4o / deepseek 等）
# private: 使用企业内部私有 LLM（OAuth2 token 认证）
LLM_PROVIDER=openai

# ---------- OpenAI / 兼容接口 ----------
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.deepseek.com/v1

# ---------- 私有 LLM（OAuth2 client_credentials） ----------
# LLM_PROVIDER=private 时生效
PRIVATE_LLM_CLIENT_ID=
PRIVATE_LLM_CLIENT_SECRET=
PRIVATE_LLM_TOKEN_URL=http://aidm-issue.apps-qa.saic-gm.com/aidm/sgmidp/oauth2/v3.0/token
PRIVATE_LLM_API_URL=http://qa-zone1.silk.saic-gm.com/aibd-diana/dianaQwen27B/v1
PRIVATE_LLM_MODEL=qwen-27b

# ============================================================
# 应用配置
# ============================================================
ENV=production
CORS_ORIGINS=*

# ============================================================
# DuckDB 数据库路径
# 打包模式下数据库文件应与可执行文件放在同一目录
# ============================================================
WIDE_DB_PATH=vcloud_wide.db

# ============================================================
# Pivot 查询 API 地址（Agent 调用数据查询的 HTTP 接口）
# 留空或删除则使用默认 http://127.0.0.1:8000/api/pivot
# ============================================================
# PIVOT_API_URL=http://127.0.0.1:8000/api/pivot
